<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/config_hint"
            android:textColor="@color/text_dim"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="@string/config_tailscale_label"
            android:textColor="@color/text"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/tailscale_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="https://albatross"
            android:inputType="textUri"
            android:textColor="@color/text"
            android:textColorHint="@color/text_dim" />

        <Button
            android:id="@+id/connect_tailscale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/connect_tailscale" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/config_lan_label"
            android:textColor="@color/text"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/lan_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="http://192.168.1.50:8080"
            android:inputType="textUri"
            android:textColor="@color/text"
            android:textColorHint="@color/text_dim" />

        <Button
            android:id="@+id/connect_lan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/connect_lan" />

    </LinearLayout>
</ScrollView>
